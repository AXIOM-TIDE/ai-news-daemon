# ── Required ──────────────────────────────────────────────────────────────────
DAEMON_PRIVATE_KEY=suiprivkey1q...    # Sui private key (bech32 or hex)
DAEMON_VESSEL_ID=0x...               # Run: node provision.js to get this

# ── Optional ──────────────────────────────────────────────────────────────────
DAEMON_NAME=sui-stats-daemon         # Label for logs
SUI_RPC_URL=                         # Defaults to mainnet public RPC
PUBLISH_INTERVAL_MS=86400000         # 24h in ms. Lower to test (e.g. 60000 = 1min)
CONK_PRICE_UNITS=0                    # 0 = free reads (default until v10). Set 1000 = $0.001 after v10 ships.
